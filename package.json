{
  "name": "hass-lovelace-kindle-screensaver",
  "version": "1.0.15",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "lint": "oxlint src/ tests/",
    "format": "oxfmt --write src/ tests/",
    "format:check": "oxfmt --check src/ tests/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.config.js",
    "test:e2e": "playwright test",
    "test:e2e:setup": "docker compose -f docker-compose.test.yml up -d --build --wait",
    "test:e2e:teardown": "docker compose -f docker-compose.test.yml down -v"
  },
  "author": "sibbl",
  "license": "MIT",
  "dependencies": {
    "cron": "^1.8.2",
    "dotenv": "^17.4.2",
    "fs-extra": "^10.0.0",
    "gm": "^1.23.1",
    "puppeteer": "^11.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/cron": "^2.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/gm": "^1.25.4",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
