{
  "name": "hass-lovelace-kindle-screensaver",
  "version": "1.1.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "lint": "oxlint src/ tests/",
    "format": "oxfmt --write src/ tests/",
    "format:check": "oxfmt --check src/ tests/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.config.js",
    "test:e2e": "playwright test",
    "test:e2e:setup": "touch .env.test && docker compose -f docker-compose.test.yml up -d --build homeassistant --wait && node scripts/setup-ha.js && docker compose -f docker-compose.test.yml up -d --build app --wait",
    "test:e2e:teardown": "docker compose -f docker-compose.test.yml down -v",
    "prepare": "husky"
  },
  "author": "sibbl",
  "license": "MIT",
  "dependencies": {
    "cron": "^4.4.0",
    "dotenv": "^17.4.2",
    "fs-extra": "^10.0.0",
    "gm": "^1.25.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/fs-extra": "^11.0.4",
    "@types/gm": "^1.25.4",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "oxfmt --write",
      "oxlint"
    ],
    "tests/**/*.{js,ts}": [
      "oxfmt --write",
      "oxlint"
    ]
  }
}
